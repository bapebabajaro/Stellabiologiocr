{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/mpcq-readonly-review.schema.json",
  "title": "MPCQ read-only review",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "batch", "reviewer", "verdicts"],
  "properties": {
    "schemaVersion": {
      "const": "mpcq-readonly-review-v1"
    },
    "batch": {
      "type": "object",
      "additionalProperties": true,
      "required": ["batchId", "ids"],
      "properties": {
        "batchId": {
          "type": "string",
          "minLength": 1
        },
        "ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^bio-q-"
          }
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "reviewedAt",
        "didNotEditFiles",
        "reviewerNotRepairAuthor",
        "didReadStandards"
      ],
      "properties": {
        "mode": {
          "const": "read_only_separate_context"
        },
        "reviewedAt": {
          "type": "string",
          "minLength": 1
        },
        "didNotEditFiles": {
          "const": true
        },
        "reviewerNotRepairAuthor": {
          "const": true
        },
        "didReadStandards": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "verdict", "checks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^bio-q-"
          },
          "verdict": {
            "enum": ["PASS", "FAIL", "TODO"]
          },
          "checks": {
            "type": "object",
            "required": [
              "stemWithin50WordsAnd320Chars",
              "neutralAnswerLabels",
              "noOneFactSolvability",
              "noAnswerShapeShortcut",
              "noLongestRowShortcut",
              "constructionNoteEnglishOnly",
              "qklAndKlmAtLeast4",
              "runtimeProjectionKemiCompatible",
              "noRuntimeImportKvPixelWrites"
            ],
            "properties": {
              "stemWithin50WordsAnd320Chars": { "type": "boolean" },
              "neutralAnswerLabels": { "type": "boolean" },
              "noOneFactSolvability": { "type": "boolean" },
              "noAnswerShapeShortcut": { "type": "boolean" },
              "noLongestRowShortcut": { "type": "boolean" },
              "constructionNoteEnglishOnly": { "type": "boolean" },
              "qklAndKlmAtLeast4": { "type": "boolean" },
              "runtimeProjectionKemiCompatible": { "type": "boolean" },
              "noRuntimeImportKvPixelWrites": { "type": "boolean" }
            }
          }
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "candidateHash"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^bio-q-"
          },
          "candidateHash": {
            "type": "string",
            "pattern": "^sha256:"
          }
        }
      }
    }
  }
}
