{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhysicalPageRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "subject",
    "bookEditionId",
    "sourceId",
    "bookPage",
    "sourceRef",
    "pageRecordIds",
    "containsRawOcr",
    "containsPageImage",
    "hashStatus",
    "runtimeEligible"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^physical-page-" },
    "schemaVersion": { "const": "physical-page-record-v1" },
    "subject": { "const": "biologi" },
    "bookEditionId": { "const": "bookedition-stella-biologi-ocr-v1" },
    "sourceId": { "type": "string" },
    "bookPage": { "type": "integer", "minimum": 1 },
    "sourceRef": { "type": "string", "pattern": "^private-source://pdfer/biologi/.+#book-page-[0-9]+$" },
    "pageRecordIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^page-record-" } },
    "containsRawOcr": { "const": false },
    "containsPageImage": { "const": false },
    "hashStatus": { "const": "pending_private_review" },
    "runtimeEligible": { "const": false }
  }
}
