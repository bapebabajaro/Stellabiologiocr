{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowledgePointCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "subject",
    "bookEditionId",
    "bookLocationId",
    "chapterId",
    "sectionId",
    "label",
    "candidateKind",
    "status",
    "pixelEligible",
    "sourceClaimIds",
    "notes"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^kp-candidate-" },
    "schemaVersion": { "const": "knowledge-point-candidate-v1" },
    "subject": { "const": "biologi" },
    "bookEditionId": { "const": "bookedition-stella-biologi-ocr-v1" },
    "bookLocationId": { "type": "string" },
    "chapterId": { "type": "string" },
    "sectionId": { "type": "string" },
    "label": { "type": "string", "maxLength": 120 },
    "candidateKind": { "const": "section_placeholder" },
    "status": { "const": "blocked_until_source_claims_reviewed_not_runtime" },
    "pixelEligible": { "const": false },
    "sourceClaimIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^sourceclaim-" }
    },
    "notes": { "type": "string" }
  }
}
