{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AtomicKpReviewDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "subject",
    "bookEditionId",
    "atomicKpReviewItemId",
    "knowledgePointId",
    "status",
    "reviewStatus",
    "decision",
    "decisionStatus",
    "reviewer",
    "reviewedAt",
    "bookLocationIds",
    "sourceClaimIds",
    "sourceAtomIds",
    "qklRole",
    "runtimeEligible",
    "runtimeImportAllowed",
    "candidateGenerationAllowed",
    "safeActiveWriteAllowed",
    "pixelBindingAllowed",
    "kvWriteAllowed",
    "importApplyAllowed"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^atomic-kp-review-decision-" },
    "schemaVersion": { "const": "atomic-kp-review-decision-v1" },
    "subject": { "const": "biologi" },
    "bookEditionId": { "const": "bookedition-stella-biologi-ocr-v1" },
    "atomicKpReviewItemId": { "type": "string", "pattern": "^atomic-kp-review-" },
    "reviewItemId": { "type": "string", "pattern": "^atomic-kp-review-" },
    "knowledgePointId": { "type": "string", "pattern": "^kp-biologi-" },
    "atomicKnowledgePointId": { "type": "string", "pattern": "^kp-biologi-" },
    "status": { "enum": ["reviewed_not_runtime", "request_fix", "reject"] },
    "reviewStatus": { "enum": ["reviewed_not_runtime", "request_fix", "reject"] },
    "decision": { "enum": ["reviewed_not_runtime", "request_fix", "reject"] },
    "decisionStatus": { "enum": ["reviewed_not_runtime", "request_fix", "reject"] },
    "reviewer": { "type": "string", "minLength": 1, "maxLength": 80 },
    "reviewedAt": { "type": "string", "format": "date-time" },
    "confidence": { "enum": ["low", "medium", "high", "synthetic"] },
    "bookLocationIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "type": "string" }
    },
    "sourceClaimIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "type": "string", "pattern": "^sourceclaim-" }
    },
    "sourceAtomIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "type": "string", "pattern": "^source-atom-" }
    },
    "qklRole": { "enum": ["core", "support", "extension"] },
    "runtimeEligible": { "const": false },
    "runtimeImportAllowed": { "const": false },
    "candidateGenerationAllowed": { "const": false },
    "safeActiveWriteAllowed": { "const": false },
    "pixelBindingAllowed": { "const": false },
    "kvWriteAllowed": { "const": false },
    "importApplyAllowed": { "const": false }
  }
}
